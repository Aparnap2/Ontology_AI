# ═══════════════════════════════════════════════════════════════
# OntologyAI — ENVIRONMENT CONFIGURATION
# Copy to .env and fill in values for production deployment
# ═══════════════════════════════════════════════════════════════

# ── Infrastructure ────────────────────────────────────────────────
POSTGRES_USER=sarthi
POSTGRES_PASSWORD=sarthi
POSTGRES_DB=sarthi
POSTGRES_PORT=5433

REDPANDA_BROKERS=localhost:19092
QDRANT_URL=http://localhost:6333
QDRANT_PORT=6333

# ── Temporal ──────────────────────────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_QUEUE=sarthi-queue
# Production: use postgres backend (not memory)
TEMPORAL_DB=postgresql
TEMPORAL_DB_HOST=localhost
TEMPORAL_DB_PORT=5433
TEMPORAL_DB_USER=sarthi
TEMPORAL_DB_PASSWORD=sarthi

# ── Ollama / LLM ──────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_CHAT_MODEL=qwen3:0.6b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# ── DSPy ─────────────────────────────────────────────────────────
DSPY_LM_MODEL=ollama_chat/qwen3:0.6b
DSPY_LM_API_BASE=http://localhost:11434

# ── Telegram ─────────────────────────────────────────────────────
TELEGRAM_API_BASE=http://localhost:8085    # tg-mock in dev
TELEGRAM_BOT_TOKEN=123:TOKEN
TELEGRAM_CHAT_ID=42
TELEGRAM_USE_MOCK=true

# ── Langfuse (self-hosted observability) ─────────────────────────
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-lf-local-dev
LANGFUSE_SECRET_KEY=sk-lf-local-dev
LANGFUSE_ENABLED=true

# ── Go API ────────────────────────────────────────────────────────
LISTEN_ADDR=:8080
RAZORPAY_WEBHOOK_SECRET=
BANK_WEBHOOK_SECRET=

# ── Python AI worker ─────────────────────────────────────────────
DATABASE_URL=postgresql://sarthi:sarthi@localhost:5433/sarthi

# ── Windmill (V5.1 managed runtime — ADR-009) ────────────────────
# Primary execution runtime. Accessible via REST API from Go core /
# Python AI worker on the internal docker network.
WINDMILL_URL=http://localhost:8000
# Generate via Windmill UI after first boot: Settings → API tokens → create.
WINDMILL_TOKEN=
WINDMILL_WORKER_TOKEN=

# ── n8n (legacy, backward compat — ADR-007) ──────────────────────
# ⚠️ n8n is internal-only and must NEVER be port-mapped to the host.
# It is reachable only via its REST API from the Go core / Python AI
# worker on the internal docker network. Do NOT add ports: 5678.
N8N_ENCRYPTION_KEY=change-me-to-a-long-random-string
N8N_OWNER_EMAIL=admin@ontologyai.local
N8N_OWNER_PASSWORD=change-me
# Internal API base URL used by workers (same docker network):
N8N_API_URL=http://n8n:5678/api/v1
# Generate via n8n after first boot: Settings → API → create key.
# Then set it here so workers can authenticate.
N8N_API_KEY=
# Dedicated postgres db/user for n8n (reuses existing postgres service,
# separate from the app's `sarthi` db to avoid schema clashes).
N8N_POSTGRES_DB=n8n
N8N_POSTGRES_USER=n8n
N8N_POSTGRES_PASSWORD=n8n
